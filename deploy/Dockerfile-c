FROM docker.io/library/golang:1.26.2-alpine3.23 AS golang
FROM docker.io/library/gcc:12.4.0 AS gcc

FROM golang AS build
WORKDIR /workspace
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=arm64 go build -o server .

FROM gcc AS run
WORKDIR /workspace
COPY --from=build /workspace/server .
COPY --from=build /workspace/docs ./docs
CMD ./server
EXPOSE 1323
